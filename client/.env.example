SERVER_URL=http://localhost:3000
XPRA_DISPLAY_BASE=10
POLL_INTERVAL_MS=2000
HANG_THRESHOLD_SECONDS=30
CRIU_BIN=/usr/sbin/criu
CHECKPOINT_DIR=/tmp/gpms-checkpoints
LOG_LEVEL=info
LOCAL_MACHINE_ID=machine-a

# Solana payer: set private key in env, or a keypair file path, or both (env takes precedence for key).
# Optional: base58, hex (32 or 64 bytes), or JSON array of numbers. Omit all to skip auto-pay.
GRIDLOCK_WALLET_PRIVATE_KEY=
# Optional: must match the pubkey of the key above; wrong pair fails fast.
GRIDLOCK_WALLET_ADDRESS=
GRIDLOCK_WALLET_KEYPAIR=
# Optional override; defaults to server RPC / devnet.
SOLANA_RPC_URL=
