SERVER_URL=http://localhost:3000
XPRA_DISPLAY_BASE=10
POLL_INTERVAL_MS=2000
HANG_THRESHOLD_SECONDS=30
CRIU_BIN=/usr/sbin/criu
CHECKPOINT_DIR=/tmp/gpms-checkpoints
LOG_LEVEL=info
LOCAL_MACHINE_ID=machine-a

# Solana payer keypair (JSON array). Optional: omit to skip auto-pay; use `npm run pay` manually.
GRIDLOCK_WALLET_KEYPAIR=
# Optional override; defaults to server RPC / devnet.
SOLANA_RPC_URL=
