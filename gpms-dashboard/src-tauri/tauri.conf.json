{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GPMS Dashboard",
  "version": "0.1.0",
  "identifier": "com.jac.gpms-dashboard",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "GPMS Dashboard",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
