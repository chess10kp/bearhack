PORT=3000
LOCAL_MACHINE_ID=machine-a
CHECKPOINT_DIR=./checkpoints
CRIU_BIN=/usr/sbin/criu
XPRA_BIN=/usr/bin/xpra
LXC_BIN=/usr/bin/lxc-create
LXC_START_BIN=/usr/bin/lxc-start
LXC_STOP_BIN=/usr/bin/lxc-stop
LXC_DESTROY_BIN=/usr/bin/lxc-destroy
LXC_INFO_BIN=/usr/bin/lxc-info
LXC_ATTACH_BIN=/usr/bin/lxc-attach
WORKER_REQUEST_TIMEOUT_MS=30000
DEFAULT_REMOTE=machine-b
POLL_INTERVAL_MS=2000
HANG_THRESHOLD_SECONDS=30
AUTO_MIGRATE=false

# Solana settlement (devnet). Leave SOLANA_TREASURY empty to skip on-chain payment.
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet
SOLANA_TREASURY=
SOLANA_BASE_LAMPORTS=1000
SOLANA_LAMPORTS_PER_SECOND=50000
